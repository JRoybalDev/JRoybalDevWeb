{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/auth/*.ts": {
      "includeFiles": "src/**"
    },
    "api/[...path].ts": {
      "includeFiles": "src/**"
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/[...path]" },
    { "source": "/dashboard/:path*", "destination": "/index.html" },
    { "source": "/projects", "destination": "/index.html" },
    { "source": "/resume", "destination": "/index.html" },
    { "source": "/experience", "destination": "/index.html" },
    { "source": "/about", "destination": "/index.html" },
    { "source": "/contact", "destination": "/index.html" },
    { "source": "/signin", "destination": "/index.html" },
    { "source": "/intake", "destination": "/index.html" }
  ]
}
