const pool = new Pool({ connectionString: Bun.env.DATABASE_URL, ssl: { rejectUnauthorized: false } });
const result = await pool.query('SELECT COUNT(*) FROM projects');
console.log('Projects count:', result.rows[0].count);
await pool.end();
" 2>&1 || echo "Command timed out or error"
