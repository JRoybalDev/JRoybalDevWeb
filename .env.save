try {
  // Check if new schema is applied
  const result = await pool.query(` SELECT EXISTS( SELECT 1 FROM 
      information_schema.columns WHERE table_name = 'projects' AND 
      column_name = 'client_id'
    ) as new_schema_applied; `);
  
  console.log("New schema applied:", result.rows[0].new_schema_applied);
  
  // Get project columns
  const cols = await pool.query(` SELECT column_name, data_type FROM 
    information_schema.columns WHERE table_name = 'projects' ORDER BY 
    ordinal_position LIMIT 10;
  `);
  
  console.log("\nFirst 10 columns:"); cols.rows.forEach(row => 
  console.log(` ${row.column_name}: ${row.data_type}`));
  
  // Count rows
  const counts = await pool.query(` SELECT (SELECT COUNT(*) FROM 
      projects) as projects, (SELECT COUNT(*) FROM clients) as clients, 
      (SELECT COUNT(*) FROM time_entries) as time_entries, (SELECT 
      COUNT(*) FROM invoices) as invoices;
  `);
  
  console.log("\nRow counts:", counts.rows[0]);
  
} catch (err) {
  console.error("Error:", err);
} finally {
  await pool.end();
}
